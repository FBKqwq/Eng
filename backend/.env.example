APP_NAME=Smart Log Analysis Backend
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=app-logs
ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_INDEX_PATTERN=app-logs-*
# ES 开启安全认证时必填（监控面板 cluster health、日志查询等共用客户端）
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=
# 与部分 Compose 模板一致时可使用 ELASTIC_PASSWORD，与 ELASTICSEARCH_PASSWORD 二选一即可
ELASTIC_PASSWORD=
LOG_PRODUCER_INTERVAL_SECONDS=1
# LangChain / LangGraph（占位，待 M3+ 配置）
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_ANALYSIS_MODEL=gpt-4o
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.2
ANALYSIS_SCHEDULE_MINUTES=15
TRIGGER_SCAN_SECONDS=30
