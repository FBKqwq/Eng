APP_NAME=Smart Log Analysis Backend
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
# Kafka / Elasticsearch / Kibana 网关统一来源为 config/gateway.yaml；
# 以下环境变量仅在“非空”时覆盖 YAML（留空则用 YAML 值）。
# 局域网协作：复制 config_example/gateway.yaml 到 config/gateway.yaml，host 填宿主机 LAN IP。
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC=
ELASTICSEARCH_HOSTS=
ELASTICSEARCH_INDEX_PATTERN=
# ES 开启安全认证时必填（监控面板 cluster health、日志查询等共用客户端）
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
# 与部分 Compose 模板一致时可使用 ELASTIC_PASSWORD，与 ELASTICSEARCH_PASSWORD 二选一即可
ELASTIC_PASSWORD=
KIBANA_BASE_URL=
LOGSTASH_HOSTS=
LOG_PRODUCER_INTERVAL_SECONDS=1
# LangChain / LangGraph 大模型调用配置
# 统一来源为 config/LLM.yaml；以下环境变量仅在“非空”时覆盖 YAML（留空则用 YAML 值）。
# 生产环境建议用 LLM_API_KEY 注入密钥，避免真实密钥写入版本库。
LLM_PROVIDER=
LLM_API_KEY=
LLM_BASE_URL=
LLM_DEFAULT_MODEL=
LLM_ANALYSIS_MODEL=
LLM_TIMEOUT_SECONDS=
LLM_TEMPERATURE=
ANALYSIS_SCHEDULE_MINUTES=15
TRIGGER_SCAN_SECONDS=30
