APP_NAME=Smart Log Analysis Backend
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=app-logs
ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_INDEX_PATTERN=app-logs-*
LOG_PRODUCER_INTERVAL_SECONDS=1

# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30

# ES 开启安全认证时必填（监控面板 cluster health、日志查询等共用客户端）
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
# 与部分 Compose 模板一致时可使用 ELASTIC_PASSWORD，与 ELASTICSEARCH_PASSWORD 二选一即可
ELASTIC_PASSWORD=changeme
LOG_PRODUCER_INTERVAL_SECONDS=1
