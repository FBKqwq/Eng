APP_NAME=Smart Log Analysis Backend
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
KAFKA_TOPIC=app-logs
ELASTICSEARCH_INDEX_PATTERN=app-logs-*
LOG_PRODUCER_INTERVAL_SECONDS=1
# 基础设施地址请在 backend/config/gateway.yaml 中配置 host 字段
# KAFKA_BOOTSTRAP_SERVERS=
# ELASTICSEARCH_HOSTS=
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
# ELASTIC_PASSWORD=
